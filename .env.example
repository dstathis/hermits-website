# Domain for Caddy HTTPS (use localhost for local dev)
DOMAIN=localhost

# Base URL (must match the public-facing URL)
BASE_URL=https://yourdomain.com

# Secret for session signing and CSRF tokens (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-in-production

# API key for JSON API access (generate with: openssl rand -hex 32)
API_KEY=change-me-in-production

# SMTP settings for email notifications
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=password
# SMTP_FROM=noreply@derangedhermits.com
